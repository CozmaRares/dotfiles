[user]
	name = Cozma Rares
	email = cozmarares11@gmail.com
[init]
	defaultBranch = main
[color]
	ui = auto
[pull]
	rebase = false
[core]
	editor = nvim
[push]
	autoSetupRemote = true
[alias]
	co = checkout
	st = status
	c = commit
	cam = commit --amend
	cne = commit --amend --no-edit
	l = log --oneline
	cl = clone --depth=1
